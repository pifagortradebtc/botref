# Скопируйте в .env и заполните своими данными
# Получить API ключ: https://www.bybit.com/app/user/api-management
# Включите только разрешение "Affiliate" (Аффилиат)

BYBIT_API_KEY=ваш_api_key
BYBIT_API_SECRET=ваш_api_secret

# Опционально: для тестовой сети Bybit
# BYBIT_BASE_URL=https://api-testnet.bybit.com

# Порт сервера (по умолчанию 3000)
# PORT=3000
